const G={
  state:'MENU',score:0,level:1,lTimer:0,lDur:12,
  enemies:[],parts:[],pups:[],pops:[],
  kills:0,combo:0,cTimer:0,maxCombo:0,
  hp:3,maxHp:3,
  pl:{x:0,y:0,tx:0,ty:0,vx:0,vy:0,shield:0,maxSh:5,inv:0},
