function loadSave(){try{const d=JSON.parse(localStorage.getItem('nvx5')||'{}');if(d.S)G.S=Object.assign(G.S,d.S);if(!Array.isArray(G.S.owned))G.S.owned=['classic'];if(!G.S.owned.includes('classic'))G.S.owned.unshift('classic');if(d.skin)G.skin=d.skin;if(d.ach)G.doneAch=d.ach;}catch(e){}}
function doSave(){try{localStorage.setItem('nvx5',JSON.stringify({S:G.S,skin:G.skin,ach:G.doneAch}));}catch(e){}}
function effectiveStats(){return{kills:G.S.kills+G.kills,maxLv:Math.max(G.S.maxLv,G.level),best:Math.max(G.S.best,Math.floor(G.score)),maxCombo:Math.max(G.S.maxCombo,G.maxCombo),shUsed:G.S.shUsed,totalCoins:G.S.totalCoins};}
const AI={
  heatmap:Array(16).fill(0),posHistory:[],maxHist:240,
  avgSpeed:0,edgeScore:0,panicScore:0,centerBias:0,fleeAngle:0,fleeCount:0,
  comboDefense:0,adaptTimer:0,adaptInterval:7,adaptLevel:0,
  lastPos:{x:0,y:0},statusMsg:'IA ANALYSE...',
  reset(){this.heatmap=Array(16).fill(0);this.posHistory=[];this.avgSpeed=0;this.edgeScore=0;this.panicScore=0;this.centerBias=0;this.fleeAngle=0;this.fleeCount=0;this.comboDefense=0;this.adaptTimer=0;this.adaptLevel=0;this.statusMsg='IA ANALYSE...';},
  tick(dt,px,py,enemies){
    const dx=px-this.lastPos.x,dy=py-this.lastPos.y;
    const spd=Math.hypot(dx,dy)/Math.max(dt,.001);
    this.avgSpeed=this.avgSpeed*.95+spd*.05;this.lastPos={x:px,y:py};
  },
  _updateStatus(){const msgs=['IA ANALYSE...','IA CALIBRE LES TRAJECTOIRES','IA DÉTECTE VOS HABITUDES','IA ADAPTE LES FLANCS'];this.statusMsg=msgs[Math.min(this.adaptLevel, 3)];document.getElementById('ai-txt').textContent=this.statusMsg;},
  getBestSpawnSide(){return Math.floor(Math.random()*4);},
  getSpeedFactor(){return 1;},
  getFlankTarget(){return null;},
  predictedPos(ahead=0.7){return{x:G.pl.x+G.pl.vx*ahead,y:G.pl.y+G.pl.vy*ahead};},
  shouldPackSpawn(){return false;},
};
let carouselIdx=0,carouselAnim=null,carouselT=0,thumbAnims={};
const shMainCv=document.getElementById('sh-main-cv');
const shMainCtx=shMainCv.getContext('2d');
function openShop(){document.getElementById('shop').classList.remove('hidden');}
function closeShop(){document.getElementById('shop').classList.add('hidden');}
function initShopTabs(){}
function renderAch(){}
function checkAch(){}
class Part{
  constructor(x,y,col,vx,vy,life,sz){this.x=x;this.y=y;this.col=col;this.vx=vx+(Math.random()-.5)*1.5;this.vy=vy+(Math.random()-.5)*1.5;this.life=this.ml=life||.65;this.sz=sz||4;}
  up(dt){this.x+=this.vx*dt*60;this.y+=this.vy*dt*60;this.vx*=.95;this.vy*=.95;this.life-=dt;}
  dr(){ctx.globalAlpha=Math.max(0,this.life/this.ml);ctx.fillStyle=this.col;ctx.fillRect(this.x-this.sz/2,this.y-this.sz/2,this.sz,this.sz);ctx.globalAlpha=1;}
}
function burst(x,y,col,n,sp){for(let i=0;i<n;i++){const a=Math.random()*Math.PI*2,s=(Math.random()*.6+.4)*sp;G.parts.push(new Part(x,y,col,Math.cos(a)*s,Math.sin(a)*s,.7+Math.random()*.5,Math.random()*4+2));}}
const PUD={shield:{col:'#00ff88',ic:'🛡'},slowmo:{col:'#00f3ff',ic:'⏱'},clear:{col:'#ff0055',ic:'💥'},heal:{col:'#ff88aa',ic:'❤'},coins:{col:'#ffe600',ic:'⬡'}};
class PUp{
  constructor(){this.type='coins';this.x=Math.random()*(canvas.width-160)+80;this.y=Math.random()*(canvas.height-160)+80;this.active=true;this.life=14;this.ang=0;}
  up(dt){this.ang+=dt*1.8;this.life-=dt;if(this.life<=0)this.active=false;}
  dr(){}
}
class Enemy{
  constructor(type,spawnPt){
    this.type=type;this.active=true;this.r=10;this.speed=130;this.hp=1;this.col='#ff0055';this.pts=10;
    this.x = spawnPt?spawnPt.x:Math.random()*canvas.width; 
    this.y = spawnPt?spawnPt.y:-45;
    const tgt={x:G.pl.x, y:G.pl.y};const ang=Math.atan2(tgt.y-this.y,tgt.x-this.x);
    this.vx=Math.cos(ang)*this.speed;this.vy=Math.sin(ang)*this.speed;this.ang=ang;
  }
  up(dt){this.x+=this.vx*dt;this.y+=this.vy*dt;}
  dr(){ctx.fillStyle=this.col;ctx.fillRect(this.x-this.r,this.y-this.r,this.r*2,this.r*2);}
  explode(){}
}
class SPop{
  constructor(x,y,txt,col){this.x=x;this.y=y;this.txt=txt;this.col=col||'#fff';this.life=1;this.vy=-1.6;}
  up(dt){this.life-=dt;this.y+=this.vy*dt*60;}
  dr(){ctx.globalAlpha=Math.max(0,this.life);ctx.fillStyle=this.col;ctx.fillText(this.txt,this.x,this.y);ctx.globalAlpha=1;}
}
function initStars(){G.stars=[];for(let i=0;i<60;i++)G.stars.push({x:Math.random()*canvas.width,y:Math.random()*canvas.height,r:Math.random()*1.6+.3,sp:Math.random()*8+2,a:Math.random()*.8+.15,col:'#fff'});}
function init(){
  resize();window.addEventListener('resize',resize);
  const mv=e=>{if(G.state!=='PLAYING'&&G.state!=='EV_PAUSE')return;const t=e.touches?e.touches[0]:e;G.pl.tx=t.clientX;G.pl.ty=t.clientY;};
  window.addEventListener('mousemove',mv);window.addEventListener('touchmove',mv,{passive:true});window.addEventListener('touchstart',mv,{passive:true});
  window.addEventListener('keydown',e=>{if(e.key==='Escape'||e.key==='p'||e.key==='P')togglePause();});
  document.getElementById('s1').onclick=()=>startGame(1);
  document.getElementById('pbtn').onclick=togglePause;
  loadSave();
  runLoader(()=>showTutoIfNeeded());
  requestAnimationFrame(loop);
}
function resize(){canvas.width=window.innerWidth;canvas.height=window.innerHeight;initStars();}
function refreshMenu(){}
function earnCoins(amt,x,y,silent){if(amt<=0)return;G.coinBuffer+=amt;}
function loseCoins(amt,x,y){if(amt<=0)return;const actual=Math.min(amt,G.S.coins);if(actual<=0)return;G.S.coins-=actual;}
function startGame(lv){
  G.level=lv;G.score=(lv-1)*200;G.lTimer=0;G.lDur=20;G.enemies=[];G.parts=[];G.pups=[];G.pops=[];G.kills=0;G.combo=0;G.cTimer=0;G.maxCombo=0;G.hp=G.maxHp=3;G.pl.shield=0;G.slowMo=0;G.shake=0;G.pl.inv=0;G.coinBuffer=0;
  G.pl.x=G.pl.tx=canvas.width/2;G.pl.y=G.pl.ty=canvas.height/2;
  G.state='PLAYING';G.nextPU=Date.now()+14000;AI.reset();
  document.getElementById('menu').classList.add('hidden');document.getElementById('gov').classList.add('hidden');
  showWave(lv);updateHUD();
}
function togglePause(){if(G.state==='PLAYING'){G.state='PAUSED';document.getElementById('menu').classList.remove('hidden');}else if(G.state==='PAUSED')doResume();}
function doResume(){G.state='PLAYING';document.getElementById('menu').classList.add('hidden');}
function showWave(lv){}
function showNotif(msg,col){}
function addCombo(){G.combo++;G.cTimer=2.8;if(G.combo>G.maxCombo)G.maxCombo=G.combo;CELIA.notifyCombo(G.combo,G);}
function resetCombo(){G.combo=0;}
function spawnE(type,pt){G.enemies.push(new Enemy(type||'red',pt||null));}
function hitPlayer(){if(G.pl.inv>0||G.pl.shield>0)return;G.hp--;G.pl.inv=2.4;resetCombo();CELIA.notifyHit(G);updateHUD();if(G.hp<=0)gameOver();}
function triggerTeleport(){}
function updateHUD(){
  UI.sc.textContent=Math.floor(G.score);
  UI.lv.textContent=G.level;
  UI.hpf.style.width=(G.hp/G.maxHp*100)+'%';
  UI.hpv.textContent=G.hp+'/'+G.maxHp;
  UI.kt.textContent=G.kills;
  UI.shf.style.width=Math.max(0,G.pl.shield/G.pl.maxSh*100)+'%';
  UI.shv.textContent=G.pl.shield>0?G.pl.shield.toFixed(1)+'s':'—';
}
function gameOver(){G.state='GAMEOVER';document.getElementById('gov').classList.remove('hidden');}
const CELIA={tick(){},notifyHit(){},notifyKill(){},notifyCombo(){},resetSession(){}};
function runLoader(cb){document.getElementById('loader').classList.add('hidden');cb();}
function showSplash(cb){cb();}
function showTutoIfNeeded(){}

let _lastScore=0,_lastCoins=0;
function animateHUD(){
  const sc=Math.floor(G.score);if(sc!==_lastScore){UI.sc.classList.remove('pop');void UI.sc.offsetWidth;if(sc-_lastScore>50)UI.sc.classList.add('pop');_lastScore=sc;}
  const coins=G.S.coins+Math.floor(G.coinBuffer);
  if(coins!==_lastCoins){
    UI.coinHud.textContent=coins; // Cache DOM updated only on change
    _lastCoins=coins;
  }
}
function loop(t){const dt=Math.min(.1,(t-G.lt)/1000);G.lt=t;if(G.state==='PLAYING'||G.state==='EV_PAUSE')update(dt);G.bgT+=dt;draw();animateHUD();requestAnimationFrame(loop);}
function update(dt){
  G.score+=dt*10*(1+G.level*.12);G.lTimer+=dt;
  const pvx=(G.pl.tx-G.pl.x)*.18,pvy=(G.pl.ty-G.pl.y)*.18;G.pl.vx=pvx;G.pl.vy=pvy;G.pl.x+=pvx;G.pl.y+=pvy;
  G.pl.x=Math.max(14,Math.min(canvas.width-14,G.pl.x));G.pl.y=Math.max(14,Math.min(canvas.height-14,G.pl.y));
  if(G.pl.shield>0)G.pl.shield=Math.max(0,G.pl.shield-dt);if(G.pl.inv>0)G.pl.inv=Math.max(0,G.pl.inv-dt);
  if(G.cTimer>0){G.cTimer-=dt;if(G.cTimer<=0)resetCombo();}
  
  // Optimisation Collision & Enemies
  for(let i=G.enemies.length-1;i>=0;i--){
    const e=G.enemies[i];e.up(dt);const dist=Math.hypot(G.pl.x-e.x,G.pl.y-e.y);
    if(dist<e.r+12){
      if(G.pl.shield>0){e.hp--;if(e.hp<=0){e.active=false;e.explode();G.kills++;}G.score+=e.pts*2;addCombo();}
      else{e.active=false;hitPlayer();}
    }
    if(!e.active&&G.state==='PLAYING'){G.enemies.splice(i,1);}
  }
  
  // Optimisation Garbage Collector via Splice inversé au lieu de .filter()
  for(let i=G.parts.length-1;i>=0;i--){
    G.parts[i].up(dt);
    if(G.parts[i].life<=0) G.parts.splice(i, 1);
  }
  for(let i=G.pops.length-1;i>=0;i--){
    G.pops[i].up(dt);
    if(G.pops[i].life<=0) G.pops.splice(i, 1);
  }
}
function draw(){
  ctx.fillStyle='rgba(2,4,8,.78)';ctx.fillRect(0,0,canvas.width,canvas.height);
  G.enemies.forEach(e=>e.dr());
  drawPlayer();
}
function drawPlayer(){ctx.fillStyle='#00f3ff';ctx.beginPath();ctx.arc(G.pl.x,G.pl.y,12,0,Math.PI*2);ctx.fill();}
init();
