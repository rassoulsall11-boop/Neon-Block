<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>NEON VORTEX</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap');
:root{
  --cy:#00f3ff;--re:#ff0055;--or:#ff9800;--gr:#00ff88;--pu:#bf00ff;--ye:#ffe600;
  --bg:#020408;--f:'Orbitron',sans-serif;
  --free:#00ff88;--rare:#00b4ff;--epic:#c84bff;--leg:#ffd700;
  --ui-xs:clamp(.48rem,1.4vw,.58rem);
  --ui-sm:clamp(.55rem,1.6vw,.68rem);
  --ui-md:clamp(.68rem,2vw,.85rem);
  --ui-lg:clamp(.85rem,2.4vw,1.1rem);
}
*{box-sizing:border-box;margin:0;padding:0;}
body,html{
  width:100%;height:100%;overflow:hidden;background:var(--bg);font-family:var(--f);
  user-select:none;touch-action:none;
}
canvas{display:block;position:absolute;top:0;left:0;width:100%;height:100%;}
/* ══ ÉCRAN DE CHARGEMENT ══ */
#loader{
  position:fixed;inset:0;z-index:9999;
  background:#020408;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:28px;
  transition:opacity .6s ease;
}
#loader.fade-out{opacity:0;pointer-events:none;}
#loader-logo{
  font-size:clamp(2.2rem,7vw,4rem);font-weight:900;letter-spacing:.15em;
  background:linear-gradient(135deg,var(--cy),var(--pu));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  position:relative;
}
#loader-logo::after{
  content:'NEON VORTEX';position:absolute;inset:0;z-index:-1;
  background:linear-gradient(135deg,var(--cy),var(--pu));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  filter:drop-shadow(0 0 44px rgba(0,243,255,1)) drop-shadow(0 0 70px rgba(191,0,255,.7));
  animation:ldrpulse 1.1s ease-in-out infinite;
}
@keyframes ldrpulse{
  0%,100%{opacity:.4;}
  50%{opacity:1;}
}
#loader-sub{font-size:var(--ui-xs);letter-spacing:.3em;color:rgba(255,255,255,.2);}
#loader-bar-wrap{width:min(280px,60vw);height:3px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden;}
#loader-bar{height:100%;width:0%;background:linear-gradient(90deg,var(--cy),var(--pu));border-radius:2px;transition:width .08s linear;}
#loader-pct{font-size:var(--ui-xs);color:rgba(255,255,255,.2);letter-spacing:.2em;margin-top:4px;}
/* ══ TUTORIEL ══ */
#tuto{
  position:absolute;inset:0;z-index:500;
  background:rgba(2,4,8,.95);backdrop-filter:blur(20px);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:0;padding:20px;
}
.hidden{display:none!important;}
.tuto-logo{
  font-size:clamp(1.4rem,4vw,2.4rem);font-weight:900;letter-spacing:.15em;
  background:linear-gradient(135deg,var(--cy),var(--pu));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  margin-bottom:6px;
}
.tuto-sub{font-size:var(--ui-xs);letter-spacing:.28em;color:rgba(255,255,255,.22);margin-bottom:22px;}
.tuto-grid{
  display:grid;grid-template-columns:1fr 1fr;
  gap:10px;width:100%;max-width:560px;margin-bottom:20px;
}
.tuto-card{
  background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);
  border-radius:14px;padding:14px 16px;
  display:flex;flex-direction:column;gap:5px;
}
.tuto-icon{font-size:1.4rem;margin-bottom:2px;}
.tuto-title{font-size:var(--ui-xs);font-weight:700;letter-spacing:.12em;color:#fff;}
.tuto-desc{font-size:var(--ui-xs);color:rgba(255,255,255,.38);line-height:1.6;letter-spacing:.02em;}
.tuto-card.hi{border-color:rgba(0,243,255,.25);background:rgba(0,243,255,.04);}
.tuto-card.hi .tuto-title{color:var(--cy);}
.tuto-card.go{border-color:rgba(255,200,0,.22);background:rgba(255,200,0,.04);}
.tuto-card.go .tuto-title{color:var(--ye);}
.tuto-card.pu{border-color:rgba(191,0,255,.22);background:rgba(191,0,255,.04);}
.tuto-card.pu .tuto-title{color:#d966ff;}
.tuto-card.re{border-color:rgba(255,0,85,.22);background:rgba(255,0,85,.04);}
.tuto-card.re .tuto-title{color:var(--re);}
#tuto-btn{
  padding:14px 48px;border-radius:13px;border:none;
  font-family:var(--f);font-size:var(--ui-md);font-weight:700;letter-spacing:.14em;
  background:linear-gradient(135deg,rgba(0,243,255,.15),rgba(191,0,255,.12));
  border:1px solid rgba(0,243,255,.3);color:#fff;cursor:pointer;transition:.2s;
}
#tuto-btn:hover,#tuto-btn:active{
  background:linear-gradient(135deg,var(--cy),var(--pu));color:#000;
  box-shadow:0 0 30px rgba(0,243,255,.4);transform:scale(1.04);
}
/* ─── HUD ─── */
#hud{position:absolute;top:0;left:0;width:100%;pointer-events:none;padding:clamp(8px,2vw,14px) clamp(10px,2.5vw,16px);display:flex;justify-content:space-between;align-items:flex-start;z-index:100;}
.hbox{background:rgba(0,243,255,.05);border:1px solid rgba(0,243,255,.15);backdrop-filter:blur(10px);border-radius:10px;padding:clamp(5px,1.5vw,9px) clamp(8px,2vw,14px);color:#fff;font-size:var(--ui-sm);line-height:1.8;}
.hbig{font-size:clamp(1.1rem,4vw,1.6rem);font-weight:900;color:var(--cy);text-shadow:0 0 14px var(--cy);transition:transform .15s,text-shadow .15s;}
.hbig.pop{transform:scale(1.22);text-shadow:0 0 32px var(--cy),0 0 60px rgba(0,243,255,.5);}
#coin-hud-wrap{font-size:var(--ui-sm);color:rgba(255,210,0,.7);transition:transform .15s,color .15s;}
#coin-hud-wrap.pop{transform:scale(1.25);color:#fff;}
.ctls{display:flex;gap:5px;pointer-events:auto;}
.btn{padding:clamp(5px,1.5vw,9px) clamp(8px,2vw,14px);background:rgba(5,5,5,.9);border:1px solid rgba(0,243,255,.4);color:#fff;cursor:pointer;font-family:var(--f);font-size:var(--ui-sm);border-radius:8px;transition:.15s;}
.btn:hover,.btn:active{background:var(--cy);color:#000;box-shadow:0 0 16px var(--cy);}
.btnr{border-color:rgba(255,0,85,.5);}
.btnr:hover,.btnr:active{background:var(--re);box-shadow:0 0 16px var(--re);color:#fff;}
#bhud{position:absolute;bottom:0;left:0;width:100%;padding:clamp(8px,2vw,12px) clamp(10px,2.5vw,14px);display:flex;justify-content:space-between;align-items:flex-end;z-index:100;pointer-events:none;}
.bw{display:flex;flex-direction:column;gap:4px;}
.bwr{align-items:flex-end;}
.bl{font-size:var(--ui-xs);color:rgba(255,255,255,.35);letter-spacing:.1em;}
.bar{width:clamp(90px,22vw,140px);height:5px;background:rgba(255,255,255,.07);border-radius:3px;overflow:hidden;}
.bf{height:100%;border-radius:3px;transition:width .25s;}
#hpf{background:linear-gradient(90deg,#ff0055,#ff7700);}
#shf{background:linear-gradient(90deg,#00ff88,#00f3ff);}
#ai-bar{position:absolute;top:clamp(54px,10vw,72px);left:50%;transform:translateX(-50%);z-index:101;pointer-events:none;display:flex;gap:6px;align-items:center;background:rgba(0,0,0,.5);border:1px solid rgba(255,100,0,.25);border-radius:20px;padding:4px 12px;font-size:var(--ui-xs);color:rgba(255,150,0,.65);letter-spacing:.1em;backdrop-filter:blur(6px);}
.ai-dot{width:5px;height:5px;border-radius:50%;background:var(--or);animation:aip 1.2s ease-in-out infinite;}
@keyframes aip{0%,100%{opacity:.35;transform:scale(1)}50%{opacity:1;transform:scale(1.5)}}
/* ─── BASE OVERLAYS ─── */
.ov{position:absolute;inset:0;background:rgba(2,4,8,.93);backdrop-filter:blur(24px);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:200;gap:12px;}
.logo{font-size:clamp(2rem,6vw,3.6rem);font-weight:900;letter-spacing:.15em;background:linear-gradient(135deg,var(--cy),var(--pu));-webkit-background-clip:text;-webkit-text-fill-color:transparent;position:relative;}
.logo::after{content:'NEON VORTEX';position:absolute;inset:0;z-index:-1;background:linear-gradient(135deg,var(--cy),var(--pu));-webkit-background-clip:text;-webkit-text-fill-color:transparent;filter:drop-shadow(0 0 44px rgba(0,243,255,.95));animation:lp 2.5s ease-in-out infinite;}
@keyframes lp{0%,100%{opacity:.3}50%{opacity:1}}
.sub{font-size:var(--ui-xs);letter-spacing:.32em;color:rgba(255,255,255,.26);}
.srow{display:flex;gap:18px;font-size:var(--ui-sm);color:rgba(255,255,255,.36);flex-wrap:wrap;justify-content:center;}
.srow b{color:var(--cy);}
.mbtns{display:flex;flex-direction:column;gap:8px;width:clamp(200px,55vw,240px);}
.mb{padding:clamp(10px,2.5vw,14px) 16px;background:rgba(0,243,255,.06);border:1px solid rgba(0,243,255,.3);color:#fff;cursor:pointer;font-family:var(--f);font-size:var(--ui-md);border-radius:9px;transition:.2s;text-align:center;letter-spacing:.08em;}
.mb:hover,.mb:active{background:var(--cy);color:#000;box-shadow:0 0 24px var(--cy);transform:scale(1.03);}
.mb.or{border-color:rgba(255,152,0,.4);color:var(--or);background:rgba(255,152,0,.06);}
.mb.or:hover,.mb.or:active{background:var(--or);color:#000;box-shadow:0 0 24px var(--or);}
.mb.ye{border-color:rgba(255,230,0,.4);color:var(--ye);background:rgba(255,230,0,.06);}
.mb.ye:hover,.mb.ye:active{background:var(--ye);color:#000;box-shadow:0 0 24px var(--ye);}
.mb.pu{border-color:rgba(191,0,255,.4);color:#d966ff;background:rgba(191,0,255,.06);}
.mb.pu:hover,.mb.pu:active{background:var(--pu);color:#fff;box-shadow:0 0 24px var(--pu);}
/* ════ BOUTIQUE ════ */
#shop{position:absolute;inset:0;z-index:250;display:flex;flex-direction:column;overflow:hidden;background:#020408;}
#shop-bg{position:absolute;inset:0;z-index:0;transition:background 0.6s ease;pointer-events:none;}
.sh-header{position:relative;z-index:3;flex-shrink:0;display:flex;align-items:center;justify-content:space-between;padding:16px 20px 0;}
.sh-title-wrap{display:flex;flex-direction:column;gap:2px;}
.sh-title{font-size:clamp(.95rem,3vw,1.5rem);font-weight:900;letter-spacing:.28em;background:linear-gradient(90deg,#ffe600,#ff9800 55%,#ff4400);-webkit-background-clip:text;-webkit-text-fill-color:transparent;filter:drop-shadow(0 0 18px rgba(255,170,0,.4));}
.sh-sub{font-size:.4rem;letter-spacing:.22em;color:rgba(255,255,255,.2);margin-top:1px;}
.sh-wallet{display:flex;align-items:center;gap:8px;background:rgba(255,200,0,.07);border:1px solid rgba(255,200,0,.18);border-radius:12px;padding:8px 14px;}
.sh-wallet-icon{font-size:1.4rem;filter:drop-shadow(0 0 8px rgba(255,210,0,.8));}
.sh-wallet-num{font-size:1.1rem;font-weight:900;color:var(--ye);line-height:1;}
.sh-wallet-lbl{font-size:.36rem;letter-spacing:.2em;color:rgba(255,200,0,.38);margin-top:2px;}
.sh-stage{position:relative;z-index:2;flex:1;min-height:0;display:flex;align-items:center;justify-content:center;padding:0 60px;overflow:hidden;}
.sh-arrow{position:absolute;top:50%;transform:translateY(-50%);z-index:4;width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.15);color:#fff;font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.2s;backdrop-filter:blur(6px);user-select:none;}
.sh-arrow:hover{background:rgba(255,255,255,.18);border-color:rgba(255,255,255,.4);transform:translateY(-50%) scale(1.08);}
#sh-prev{left:10px;}
#sh-next{right:10px;}
.sh-main-card{display:flex;flex-direction:column;align-items:center;gap:0;width:100%;max-width:380px;animation:cardIn .35s cubic-bezier(.22,.84,.32,1);}
@keyframes cardIn{from{opacity:0;transform:scale(.93) translateY(10px)}to{opacity:1;transform:none}}
.sh-main-prev{position:relative;width:min(260px,55vw,45vh);aspect-ratio:1;border-radius:24px;overflow:hidden;border:2px solid rgba(255,255,255,.1);background:#020408;display:flex;align-items:center;justify-content:center;box-shadow:0 0 60px rgba(0,0,0,.8);}
.sh-main-prev::before{content:'';position:absolute;inset:0;border-radius:24px;transition:background .5s;pointer-events:none;z-index:0;}
.sh-main-prev.r-free::before{background:radial-gradient(ellipse at center,rgba(0,255,136,.14) 0%,transparent 65%);}
.sh-main-prev.r-rare::before{background:radial-gradient(ellipse at center,rgba(0,180,255,.16) 0%,transparent 65%);}
.sh-main-prev.r-epic::before{background:radial-gradient(ellipse at center,rgba(200,75,255,.18) 0%,transparent 65%);}
.sh-main-prev.r-legend::before{background:radial-gradient(ellipse at center,rgba(255,200,0,.18) 0%,transparent 65%);}
#sh-main-cv{display:block;position:relative;z-index:1;}
.sh-main-stripe{position:absolute;top:0;left:0;right:0;height:3px;z-index:2;}
.r-free .sh-main-stripe,.sh-main-prev.r-free .sh-main-stripe{background:linear-gradient(90deg,transparent,var(--free),transparent);}
.r-rare .sh-main-stripe,.sh-main-prev.r-rare .sh-main-stripe{background:linear-gradient(90deg,transparent,var(--rare),transparent);}
.r-epic .sh-main-stripe,.sh-main-prev.r-epic .sh-main-stripe{background:linear-gradient(90deg,transparent,var(--epic),transparent);}
.r-legend .sh-main-stripe,.sh-main-prev.r-legend .sh-main-stripe{background:linear-gradient(90deg,transparent,var(--leg),#ff9800,var(--leg),transparent);background-size:200% 100%;animation:goldslide 2s linear infinite;}
@keyframes goldslide{0%{background-position:100%}100%{background-position:-100%}}
.sh-eq-tag{position:absolute;top:10px;left:10px;z-index:3;font-size:.45rem;font-weight:700;letter-spacing:.12em;padding:3px 8px;border-radius:8px;background:rgba(0,243,255,.22);color:var(--cy);border:1px solid rgba(0,243,255,.5);}
.sh-r-badge{position:absolute;top:10px;right:10px;z-index:3;font-size:.44rem;font-weight:700;letter-spacing:.1em;padding:3px 8px;border-radius:8px;}
.r-free .sh-r-badge{background:rgba(0,255,136,.18);color:var(--free);border:1px solid rgba(0,255,136,.35);}
.r-rare .sh-r-badge{background:rgba(0,180,255,.18);color:var(--rare);border:1px solid rgba(0,180,255,.35);}
.r-epic .sh-r-badge{background:rgba(200,75,255,.18);color:var(--epic);border:1px solid rgba(200,75,255,.35);}
.r-legend .sh-r-badge{background:rgba(255,200,0,.18);color:var(--leg);border:1px solid rgba(255,200,0,.35);}
.sh-main-info{width:100%;padding:14px 4px 4px;display:flex;flex-direction:column;gap:6px;align-items:center;text-align:center;}
.sh-main-name{font-size:clamp(1.1rem,4vw,1.8rem);font-weight:900;letter-spacing:.18em;color:#fff;text-shadow:0 0 20px rgba(255,255,255,.15);}
.sh-main-desc{font-size:.54rem;color:rgba(255,255,255,.35);letter-spacing:.04em;line-height:1.6;max-width:320px;}
.sh-main-traits{display:flex;gap:5px;flex-wrap:wrap;justify-content:center;margin-top:2px;}
.sh-trait{font-size:.42rem;letter-spacing:.1em;padding:3px 8px;border-radius:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.4);}
.sh-buy-zone{width:100%;display:flex;align-items:center;gap:10px;padding-top:12px;border-top:1px solid rgba(255,255,255,.07);margin-top:4px;}
.sh-price-block{display:flex;flex-direction:column;gap:2px;min-width:70px;}
.sh-price-lbl{font-size:.36rem;color:rgba(255,255,255,.22);letter-spacing:.16em;}
.sh-price-val{font-size:1.2rem;font-weight:900;line-height:1;}
.sh-price-val.pv-gold{color:var(--ye);}
.sh-price-val.pv-own{color:rgba(0,243,255,.55);font-size:.7rem;letter-spacing:.06em;}
.sh-price-val.pv-free{color:var(--free);font-size:.8rem;}
.sh-price-val.pv-red{color:rgba(255,80,80,.55);font-size:.85rem;}
.sh-action{flex:1;padding:13px;border-radius:12px;border:none;font-family:var(--f);font-size:.68rem;font-weight:700;letter-spacing:.1em;cursor:pointer;transition:.2s;text-align:center;}
.sha-buy{background:linear-gradient(135deg,rgba(255,200,0,.18),rgba(255,110,0,.12));border:1px solid rgba(255,190,0,.4);color:var(--ye);}
.sha-buy:hover{background:linear-gradient(135deg,#ffe600,#ff9800);color:#000;box-shadow:0 0 28px rgba(255,200,0,.55);transform:scale(1.02);}
.sha-equip{background:linear-gradient(135deg,rgba(0,243,255,.12),rgba(0,80,200,.1));border:1px solid rgba(0,243,255,.35);color:var(--cy);}
.sha-equip:hover{background:linear-gradient(135deg,var(--cy),#0088ff);color:#000;box-shadow:0 0 28px rgba(0,243,255,.5);transform:scale(1.02);}
.sha-on{background:rgba(0,243,255,.05);border:1px solid rgba(0,243,255,.15);color:rgba(0,243,255,.35);cursor:default;}
.sha-cant{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);color:rgba(255,255,255,.18);cursor:default;}
.sha-free{background:linear-gradient(135deg,rgba(0,255,136,.12),rgba(0,180,80,.1));border:1px solid rgba(0,255,136,.35);color:var(--free);}
.sha-free:hover{background:linear-gradient(135deg,#00ff88,#00cc66);color:#000;box-shadow:0 0 24px rgba(0,255,136,.45);transform:scale(1.02);}
.sh-thumbbar{position:relative;z-index:3;flex-shrink:0;padding:8px 20px 14px;display:flex;align-items:center;gap:7px;overflow-x:auto;scrollbar-width:none;justify-content:center;}
.sh-thumbbar::-webkit-scrollbar{display:none;}
.sh-thumb{flex-shrink:0;width:52px;height:52px;border-radius:12px;background:#050a14;border:2px solid rgba(255,255,255,.08);cursor:pointer;overflow:hidden;display:flex;align-items:center;justify-content:center;transition:.2s;position:relative;}
.sh-thumb:hover{border-color:rgba(255,255,255,.3);transform:translateY(-2px);}
.sh-thumb.th-sel{transform:translateY(-4px) scale(1.1);}
.sh-thumb.r-free.th-sel{border-color:var(--free);box-shadow:0 4px 16px rgba(0,255,136,.4);}
.sh-thumb.r-rare.th-sel{border-color:var(--rare);box-shadow:0 4px 16px rgba(0,180,255,.4);}
.sh-thumb.r-epic.th-sel{border-color:var(--epic);box-shadow:0 4px 16px rgba(200,75,255,.4);}
.sh-thumb.r-legend.th-sel{border-color:var(--leg);box-shadow:0 4px 16px rgba(255,200,0,.45);}
.sh-thumb canvas{display:block;}
.sh-thumb::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;}
.sh-thumb.r-free::after{background:var(--free);}
.sh-thumb.r-rare::after{background:var(--rare);}
.sh-thumb.r-epic::after{background:var(--epic);}
.sh-thumb.r-legend::after{background:linear-gradient(90deg,var(--leg),#ff9800,var(--leg));}
.sh-thumb.th-lock{opacity:.35;}
.sh-thumb.th-lock::before{content:'🔒';position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:.8rem;z-index:2;background:rgba(2,4,8,.6);}
.sh-footer{position:relative;z-index:3;flex-shrink:0;padding:4px 20px 14px;}
/* ─── ACHIEVEMENTS ─── */
#achpan{position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(2,4,8,.96);backdrop-filter:blur(22px);display:flex;flex-direction:column;align-items:center;z-index:250;gap:10px;padding:24px 14px 0;}
.achtitle{font-size:clamp(1.2rem,4vw,1.8rem);font-weight:900;letter-spacing:.2em;color:var(--ye);text-shadow:0 0 26px var(--ye);flex-shrink:0;}
.achscroll{flex:1;overflow-y:auto;width:100%;max-width:520px;}
.achgrid{display:flex;flex-direction:column;gap:8px;padding:4px 4px 16px;}
.achi{display:flex;align-items:center;gap:11px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:10px;padding:10px 13px;}
.achi.done{border-color:rgba(255,230,0,.4);background:rgba(255,230,0,.06);}
.achic{font-size:1.4rem;min-width:30px;text-align:center;}
.achif{flex:1;min-width:0;}
.achin{font-size:.66rem;letter-spacing:.07em;color:rgba(255,255,255,.75);}
.achi.done .achin{color:var(--ye);}
.achid{font-size:.53rem;color:rgba(255,255,255,.3);margin-top:2px;}
.achip{font-size:.48rem;color:rgba(255,255,255,.22);margin-top:3px;}
.achib{width:100%;height:3px;background:rgba(255,255,255,.07);border-radius:2px;margin-top:4px;overflow:hidden;}
.achibf{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--ye),var(--or));}
.achfoot{flex-shrink:0;padding:10px 0 16px;}
/* ─── FX ─── */
